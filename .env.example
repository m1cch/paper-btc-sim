PAPER_MODE=true
# true = входы при YES/NO ≥0,60; false = только цены и график
AUTO_TRADE=false
INITIAL_DEPOSIT=300
# Локально: порт дашборда. В Render/Railway/Fly используйте PORT от платформы (или не задавайте).
DASHBOARD_PORT=8080
# Опционально: каталог для db/trades.db и trades.log (в облаке смонтируйте том, например DATA_DIR=/data).
# DATA_DIR=/data
# Через запятую: разрешённые Origin для дашборда на Vercel (fetch к этому API). Пример:
# CORS_ORIGINS=https://polymarket-bot.vercel.app
# Опрос midpoints, сек (0.08 ≈ 80 мс; в коде min 0.02). Список Gamma кэшируется отдельно.
PRICE_REFRESH_SECONDS=0.08
# Как часто заново тянуть список событий Gamma (сек). Midpoints — каждый тик.
GAMMA_REFRESH_SECONDS=2
# Сколько секунд подряд Gamma должен отдавать один и тот же slug, чтобы считать смену 15m окна (анти-мигание).
SLUG_CHANGE_CONFIRM_SECONDS=1.5
# После привязки окна / arm — пауза перед первым входом (сек), от одного шумного тика midpoint.
ENTRY_DELAY_AFTER_ARM_SECONDS=2.0
# Сколько подряд тиков подряд должна держаться сторона входа (YES/NO ≥0,60 и ≤ ENTRY_MAX_PRICE).
ENTRY_CONFIRM_TICKS=3
# Макс. цена стороны для первого входа и для разворота после стопа 0,40 (не покупать «дорогую» противоположную сторону ~0,90).
ENTRY_MAX_PRICE=0.70
# Сколько подряд тиков с mid ≥0,90 нужно для тейк-профита (меньше ложных срабатываний на одном шумном тике).
TAKE_PROFIT_CONFIRM_TICKS=2
# yes_mid + no_mid должны быть в этом диапазоне (иначе midpoint считается мусорным, вход блокируется).
MID_SUM_MIN=0.93
MID_SUM_MAX=1.07
# Реже писать состояние в SQLite (сек), без потери логики в RAM
PERSIST_DEBOUNCE_SECONDS=0.22
# Не чаще (сек) писать цену в SQLite для графика из БД; в памяти точка каждый тик
DB_PRICE_SAMPLE_MIN_SECONDS=0.05
# Первая ставка $1, далее ×2 на каждом развороте
BASE_STAKE_USD=1
GAMMA_SERIES_ID=10192
MIN_SECONDS_TO_END=30
